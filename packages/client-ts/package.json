{
  "name": "@manifold/client",
  "version": "0.1.0",
  "description": "Engine client SDK: transport (WS/SSE), reconnect, subscription registry, recovery, protobuf",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.2.0",
    "@manifold/proto-gen": "workspace:*"
  },
  "devDependencies": {
    "@grpc/grpc-js": "^1.12.0",
    "@grpc/proto-loader": "^0.7.13",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "undici": "^6.21.0"
  }
}
