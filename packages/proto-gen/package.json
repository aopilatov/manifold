{
  "name": "@socket/proto-gen",
  "version": "0.1.0",
  "description": "Сгенерированные protobuf-es типы из proto/socket.proto (общие для client-ts и web)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "generate": "buf generate ../../proto --template buf.gen.yaml",
    "build": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.45.0",
    "@bufbuild/protoc-gen-es": "^2.2.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.2.0"
  }
}
