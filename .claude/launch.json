{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": [
        "--filter",
        "@manifold/web",
        "dev"
      ],
      "port": 5173
    },
    {
      "name": "docs",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "-y",
        "serve",
        "dist-docs",
        "-l",
        "4321"
      ],
      "port": 4321
    }
  ]
}